# ── P0: internal/ never reaches the repository ──────────────────────────────
internal/

# ── Large numerical artefacts (results JSON stays tracked) ──────────────────
*.npy
*.npz
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
claims/*/runs/**/logs/
claims/*/runs/**/*.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.pytest_cache/
pytest-cache-files-*/
.venv/
venv/
.ipynb_checkpoints/

# ── LaTeX build artefacts (papers) ───────────────────────────────────────────
publish/papers/**/*.aux
publish/papers/**/*.bbl
publish/papers/**/*.blg
publish/papers/**/*.out
publish/papers/**/*.synctex.gz
publish/papers/**/*.toc

# ── changelog query cache (rebuildable from changelog/log.jsonl) ──────────────
changelog/.cache/

# ── catalog incremental hash cache (rebuildable; ADR-0001) ───────────────────
verification/.cache/

# ── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Google Drive for Desktop sync artifacts ─────────────────────────────────
#    Transient: Drive creates/deletes these mid-sync and they break
#    `git add --all`; they must never reach the repo or GitHub.
.tmp.driveupload/
.tmp.drivedownload/
.tmp.drive*
*.tmp.driveupload
*.tmp.drivedownload
.driveupload/
.drivedownload/
*.gdoc
*.gsheet
*.gslides
*.gdraw
*.gform
*.glink
*.gmap
*.gsite

# ── transient / editor / lock files (never tracked) ──────────────────────────
*.tmp
.*.tmp
*~
*.swp
.*.swp
.~lock.*
.goutputstream-*
~$*
ehthumbs.db
